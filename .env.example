# 启用的平台，逗号分隔 (feishu, qq)
# PLATFORMS=feishu

# QQ 桥接端口
# QQ_BRIDGE_PORT=18080

# 飞书应用凭证
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
# 可选兜底：启动时会自动解析当前机器人的 open_id；仅在 API 解析失败时手动配置
# FEISHU_BOT_OPEN_ID=ou_xxx

# DeepSeek API Key（RCM LLM 调用用）
DEEPSEEK_API_KEY=sk-xxx

# 以下可选，不设则使用默认值
# TARGET_REPO=owner/repo
# REPO_PATH=./repo
# RCM_BIN=accelerate
# GH_PATH_PREFIX=gh
# RCM_RUN_TIMEOUT_SECONDS=420

# Mempalace 可选配置（语义检索增强）
# MEMPALACE_BIN=mempalace
# MEMPALACE_ENABLED=auto   # auto | true | false
# MEMPALACE_PALACE_PATH=
