# 飞书应用凭证
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx

# DeepSeek API Key（RCM LLM 调用用）
DEEPSEEK_API_KEY=sk-xxx

# 以下可选，不设则使用默认值
# TARGET_REPO=owner/repo
# REPO_PATH=./repo
# RCM_BIN=accelerate
# GH_PATH_PREFIX=gh
# RCM_RUN_TIMEOUT_SECONDS=420

# Mempalace 可选配置（语义检索增强）
# MEMPALACE_BIN=mempalace
# MEMPALACE_ENABLED=auto   # auto | true | false
# MEMPALACE_PALACE_PATH=
